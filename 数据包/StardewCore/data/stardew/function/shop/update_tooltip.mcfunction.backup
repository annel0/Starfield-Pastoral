# 根据item_id更新tooltip显示内容
# 前提: storage stardew:temp tooltip_data 包含物品数据

# === 春季种子 ===
execute if data storage stardew:temp tooltip_data{item_id:"parsnip_seeds"} run data modify entity @e[type=text_display,tag=shop_tooltip,limit=1] text set value '[{"text":"防风草种子\\n","color":"white","italic":false,"bold":true},{"text":"售价：","color":"white","italic":false,"bold":false},{"text":"20G","color":"gold","italic":false,"bold":true},{"text":"\\n物品种类：","color":"white","italic":false,"bold":false},{"text":"种子","color":"dark_green","italic":false,"bold":true},{"text":"\\n春季播种。4天成熟。","color":"gray","italic":false,"bold":false}]'

execute if data storage stardew:temp tooltip_data{item_id:"green_bean_starter"} run data modify entity @e[type=text_display,tag=shop_tooltip,limit=1] text set value '{"text":"绿豆种子\\n春季播种。10天成熟。\\n收获后会再生。\\n售价: 60G","color":"white","italic":false}'

execute if data storage stardew:temp tooltip_data{item_id:"cauliflower_seeds"} run data modify entity @e[type=text_display,tag=shop_tooltip,limit=1] text set value '{"text":"花椰菜种子\\n春季播种。12天成熟。\\n售价: 80G","color":"white","italic":false}'

