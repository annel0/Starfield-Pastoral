execute unless score @s sd_monster_hp matches 1.. run scoreboard players set @s sd_monster_hp 20
execute unless score @s sd_monster_max_hp matches 1.. run scoreboard players set @s sd_monster_max_hp 20
execute unless score @s sd_monster_damage matches 0.. run scoreboard players set @s sd_monster_damage 5

# 保存怪物的原始名字（用于血量显示）
# 让怪物保留原版名字，不设置自定义名字

# 【武器设置】武器已在summon时设置，这里不需要再设置（避免覆盖）
# 骷髅/流浪者：弓+箭
# 凋灵骷髅：石剑
# 恼鬼：铁剑

# 移除初始化标签，添加正式怪物标签
tag @s remove sd_monster_init
tag @s add sd_monster

# 设置发光效果（1.21+ 使用秒数，-1 表示无限）
effect give @s minecraft:glowing infinite 0 true

# 【关键】给怪物加抗性效果，让它不会被正常伤害杀死
# 只能被我们的自定义伤害系统杀死（1.21+ 使用 infinite 或 -1）
effect give @s minecraft:resistance infinite 255 true

