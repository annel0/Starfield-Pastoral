# ================================================================
# 星露谷物语 - 检查挤山羊奶
# ================================================================
# 用途：玩家使用奶桶时检查是否可以挤山羊奶
# @s = 玩家
# ================================================================

# 检查玩家手持奶桶（CMD 8008）
execute if items entity @s weapon.mainhand *[custom_data~{stardew:{id:8008}}] run function stardew:animal/interact/try_milk_goat
