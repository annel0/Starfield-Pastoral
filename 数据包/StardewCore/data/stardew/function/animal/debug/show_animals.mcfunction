# ================================================================
# 星露谷物语 - 显示所有动物（包括隐形的）
# ================================================================
# 用途：在所有隐形动物头上显示发光粒子

execute as @e[type=#stardew:animals,tag=stardew.animal] at @s run particle minecraft:glow ~ ~1 ~ 0.2 0.5 0.2 0 5 force

tellraw @s [{"text":"[调试] ","color":"green"},{"text":"已显示所有动物的位置（发光粒子）"}]
