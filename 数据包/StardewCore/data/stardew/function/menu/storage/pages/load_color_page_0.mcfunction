# data/stardew/function/menu/storage/pages/load_color_page_0.mcfunction
# 加载颜色页面0 - 颜色0-6

# 存储当前玩家序列号
execute store result score #CurrentPlayer sd_menu_ctrl run scoreboard players get @a[scores={sd_menu_sequence=1..},limit=1] sd_menu_sequence

# Slot 1-7: 显示不同颜色的bundle
execute as @e[type=item_display,tag=sd_menu_button,tag=sd_menu_slot_1] if score @s sd_menu_entity_num = #CurrentPlayer sd_menu_ctrl run data merge entity @s {item:{id:"minecraft:bundle",count:1}}
