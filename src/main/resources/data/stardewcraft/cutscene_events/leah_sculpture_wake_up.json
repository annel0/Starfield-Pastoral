{
  "id": "leah_sculpture_wake_up",
  "skippable": false,
  "trigger": { "type": "wake_up" },
  "preconditions": [
    { "type": "not_saw_event", "id": "leah_sculpture_wake_up" },
    { "type": "friendship", "npc": "leah", "min": 1500 },
    { "type": "weather", "weather": "sunny" }
  ],
  "commands": [
    { "cmd": "comment", "text": "=== SDV Farm Event 992253: Leah gives sculpture ===" },

    { "cmd": "lock_player" },
    { "cmd": "fade", "mode": "out", "ticks": 10 },

    { "cmd": "warp", "actor": "player", "x": 0, "y": 0, "z": 0, "anchor": "farm_spawn" },
    { "cmd": "face_actor", "actor": "player", "yaw": 90 },

    { "cmd": "spawn_actor", "actor": "fake_player", "npc_id": "player",
      "x": 0, "y": 0, "z": 0, "facing": 90, "anchor": "farm_spawn" },

    { "cmd": "spawn_actor", "actor": "leah", "npc_id": "leah",
      "x": -2, "y": 0, "z": 0, "facing": -90, "anchor": "farm_spawn" },

    { "cmd": "camera", "x": -2.432, "y": 0.378, "z": 2.928,
      "yaw": -141.4, "pitch": 13.5, "anchor": "farm_spawn" },

    { "cmd": "fade", "mode": "in", "ticks": 20 },
    { "cmd": "pause", "ticks": 30 },

    { "cmd": "speak", "npc_id": "leah", "text": "event.leah_sculpture.greeting" },
    { "cmd": "speak", "npc_id": "leah", "text": "event.leah_sculpture.gift" },

    { "cmd": "hold_item", "actor": "leah", "item": "stardewcraft:leah_sculpture", "ticks": 40 },
    { "cmd": "play_sound", "sound": "stardewcraft:reward", "volume": 1.0, "pitch": 1.0 },
    { "cmd": "add_item", "item": "stardewcraft:leah_sculpture", "count": 1 },
    { "cmd": "message", "text": "event.leah_sculpture.received" },
    { "cmd": "pause", "ticks": 40 },

    { "cmd": "speak", "npc_id": "leah", "text": "event.leah_sculpture.goodbye" },

    { "cmd": "remove_actor", "actor": "leah" },
    { "cmd": "remove_actor", "actor": "fake_player" },
    { "cmd": "unlock_player" },
    { "cmd": "end" }
