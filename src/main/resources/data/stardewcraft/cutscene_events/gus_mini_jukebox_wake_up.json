{
  "id": "gus_mini_jukebox_wake_up",
  "skippable": false,
  "trigger": { "type": "wake_up" },
  "preconditions": [
    { "type": "not_saw_event", "id": "gus_mini_jukebox_wake_up" },
    { "type": "friendship", "npc": "gus", "min": 1250 },
    { "type": "weather", "weather": "sunny" }
  ],
  "commands": [
    { "cmd": "comment", "text": "=== SDV Farm Event 980558: Gus gives Mini-Jukebox ===" },

    { "cmd": "lock_player" },
    { "cmd": "fade", "mode": "out", "ticks": 10 },

    { "cmd": "warp", "actor": "player", "x": 0, "y": 0, "z": 0, "anchor": "farm_spawn" },
    { "cmd": "face_actor", "actor": "player", "yaw": 90 },

    { "cmd": "spawn_actor", "actor": "fake_player", "npc_id": "player",
      "x": 0, "y": 0, "z": 0, "facing": 90, "anchor": "farm_spawn" },

    { "cmd": "spawn_actor", "actor": "gus", "npc_id": "gus",
      "x": -2, "y": 0, "z": 0, "facing": -90, "anchor": "farm_spawn" },

    { "cmd": "camera", "x": -2.432, "y": 0.378, "z": 2.928,
      "yaw": -141.4, "pitch": 13.5, "anchor": "farm_spawn" },

    { "cmd": "fade", "mode": "in", "ticks": 20 },
    { "cmd": "pause", "ticks": 30 },

    { "cmd": "speak", "npc_id": "gus", "text": "event.gus_mini_jukebox.greeting" },
    { "cmd": "speak", "npc_id": "gus", "text": "event.gus_mini_jukebox.friendship" },
    { "cmd": "speak", "npc_id": "gus", "text": "event.gus_mini_jukebox.gift" },

    { "cmd": "hold_item", "actor": "gus", "item": "stardewcraft:jukebox", "ticks": 40 },
    { "cmd": "play_sound", "sound": "stardewcraft:reward", "volume": 1.0, "pitch": 1.0 },
    { "cmd": "add_item", "item": "stardewcraft:jukebox", "count": 1 },
    { "cmd": "message", "text": "event.gus_mini_jukebox.received" },
    { "cmd": "pause", "ticks": 40 },

    { "cmd": "speak", "npc_id": "gus", "text": "event.gus_mini_jukebox.blueprints" },
    { "cmd": "play_sound", "sound": "stardewcraft:reward", "volume": 1.0, "pitch": 1.0 },
    { "cmd": "add_recipe", "recipe": "mini_jukebox" },
    { "cmd": "message", "text": "event.gus_mini_jukebox.learned" },
    { "cmd": "pause", "ticks": 40 },

    { "cmd": "speak", "npc_id": "gus", "text": "event.gus_mini_jukebox.goodbye" },

    { "cmd": "remove_actor", "actor": "gus" },
    { "cmd": "remove_actor", "actor": "fake_player" },
    { "cmd": "unlock_player" },
    { "cmd": "end" }
  ]
}