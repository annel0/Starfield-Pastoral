{
  "id": "demetrius_cave_choice_wake_up",
  "skippable": false,
  "trigger": { "type": "wake_up" },
  "preconditions": [
    { "type": "not_saw_event", "id": "demetrius_cave_choice_wake_up" },
    { "type": "money", "min": 25000 }
  ],
  "commands": [
    { "cmd": "comment", "text": "=== SDV Event 65: Demetrius offers cave choice — adapted to farm-door layout ===" },

    { "cmd": "lock_player" },
    { "cmd": "fade", "mode": "out", "ticks": 10 },

    { "cmd": "warp", "actor": "player", "x": 0, "y": 0, "z": 0, "anchor": "farm_spawn" },
    { "cmd": "face_actor", "actor": "player", "yaw": 90 },

    { "cmd": "spawn_actor", "actor": "fake_player", "npc_id": "player",
      "x": 0, "y": 0, "z": 0, "facing": 90, "anchor": "farm_spawn" },

    { "cmd": "spawn_actor", "actor": "demetrius", "npc_id": "demetrius",
      "x": -2, "y": 0, "z": 0, "facing": -90, "anchor": "farm_spawn" },

    { "cmd": "camera", "x": -2.432, "y": 0.378, "z": 2.928,
      "yaw": -141.4, "pitch": 13.5, "anchor": "farm_spawn" },

    { "cmd": "fade", "mode": "in", "ticks": 20 },
    { "cmd": "pause", "ticks": 30 },

    { "cmd": "speak", "npc_id": "demetrius", "text": "event.demetrius_cave.greeting" },
    { "cmd": "speak", "npc_id": "demetrius", "text": "event.demetrius_cave.breakthrough" },
    { "cmd": "speak", "npc_id": "demetrius", "text": "event.demetrius_cave.empty_cave" },
    { "cmd": "speak", "npc_id": "demetrius", "text": "event.demetrius_cave.proposal" },
    { "cmd": "speak", "npc_id": "demetrius", "text": "event.demetrius_cave.offer_choice" },

    {
      "cmd": "question",
      "text": "event.demetrius_cave.question",
      "choices": [
        {
          "text": "event.demetrius_cave.choice_bats",
          "commands": [
            { "cmd": "set_cave_choice", "choice": "fruit_bats" },
            { "cmd": "speak", "npc_id": "demetrius", "text": "event.demetrius_cave.confirm_bats" }
          ]
        },
        {
          "text": "event.demetrius_cave.choice_mushrooms",
          "commands": [
            { "cmd": "set_cave_choice", "choice": "mushrooms" },
            { "cmd": "speak", "npc_id": "demetrius", "text": "event.demetrius_cave.confirm_mushrooms" }
          ]
        }
      ]
    },

    { "cmd": "speak", "npc_id": "demetrius", "text": "event.demetrius_cave.goodbye" },

    { "cmd": "remove_actor", "actor": "demetrius" },
    { "cmd": "remove_actor", "actor": "fake_player" },
    { "cmd": "unlock_player" },
    { "cmd": "end" }
  ]
}
