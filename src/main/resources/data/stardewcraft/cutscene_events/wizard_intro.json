{
  "id": "wizard_intro",
  "skippable": true,
  "trigger": {
    "type": "manual"
  },
  "preconditions": [],
  "commands": [
    { "cmd": "comment", "text": "=== Wizard First Meeting Cutscene ===" },
    { "cmd": "lock_player" },
    { "cmd": "fade", "mode": "out", "ticks": 10 },

    { "cmd": "comment", "text": "Setup: hide real wizard, no fake_player yet" },
    { "cmd": "hide_npc", "npc_id": "wizard" },
    { "cmd": "spawn_actor", "actor": "wizard", "npc_id": "wizard", "x": -178.5, "y": 34, "z": 56.5, "relative": false, "facing": 180 },

    { "cmd": "comment", "text": "=== Smooth continuous orbit 01→02→03→04 (no pauses, ~80 ticks total) ===" },
    { "cmd": "camera", "x": -183.908, "y": 35.006, "z": 60.758, "yaw": -129.5, "pitch": 11.2, "relative": false },
    { "cmd": "fade", "mode": "in", "ticks": 15 },
    { "cmd": "camera", "x": -178.947, "y": 35.006, "z": 61.882, "yaw": -178.8, "pitch": 8.2, "relative": false, "ticks": 27 },
    { "cmd": "camera", "x": -174.556, "y": 35.006, "z": 58.951, "yaw": 122.0, "pitch": 12.6, "relative": false, "ticks": 27 },
    { "cmd": "camera", "x": -175.978, "y": 35.006, "z": 54.77, "yaw": 29.3, "pitch": 16.7, "relative": false, "ticks": 26 },

    { "cmd": "comment", "text": "Camera holds at 04. Spawn fake_player at the door and walk in" },
    { "cmd": "spawn_actor", "actor": "fake_player", "npc_id": "player", "x": -178.5, "y": 34, "z": 63.5, "relative": false, "facing": 180 },
    { "cmd": "move_actor", "actor": "fake_player", "x": -178.5, "y": 34, "z": 58.5, "ticks": 50, "relative": false },
    { "cmd": "pause", "ticks": 50 },

    { "cmd": "comment", "text": "Wizard turns to face the player, then reacts" },
    { "cmd": "face_actor", "actor": "wizard", "face_actor": "fake_player" },
    { "cmd": "pause", "ticks": 5 },
    { "cmd": "play_sound", "sound": "stardewcraft:dwop" },
    { "cmd": "emote", "actor": "wizard", "emote": "exclamation" },
    { "cmd": "jump", "actor": "wizard", "strength": 0.3 },
    { "cmd": "pause", "ticks": 20 },

    { "cmd": "comment", "text": "Hard cut to 05: wizard closeup (instant, no ticks)" },
    { "cmd": "camera", "x": -176.844, "y": 35.381, "z": 59.505, "yaw": 151.2, "pitch": 31.5, "relative": false },
    { "cmd": "speak", "npc_id": "wizard", "text": "event.wizard_intro.line1" },
    { "cmd": "pause", "ticks": 10 },
    { "cmd": "speak", "npc_id": "wizard", "text": "event.wizard_intro.line2" },
    { "cmd": "pause", "ticks": 10 },
    { "cmd": "speak", "npc_id": "wizard", "text": "event.wizard_intro.line3" },

    { "cmd": "comment", "text": "Mark first met" },
    { "cmd": "set_flag", "flag": "wizardFirstMet" },

    { "cmd": "skippable" },
    { "cmd": "comment", "text": "Fade out, clean up, end" },
    { "cmd": "fade", "mode": "out", "ticks": 15 },
    { "cmd": "remove_actor", "actor": "wizard" },
    { "cmd": "remove_actor", "actor": "fake_player" },
    { "cmd": "camera", "action": "reset" },
    { "cmd": "unlock_player" },
    { "cmd": "fade", "mode": "in", "ticks": 15 },
    { "cmd": "end" }
  ]
}
